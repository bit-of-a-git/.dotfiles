# ~/.bash_exports

# Add color in manpages for less
export LESS_TERMCAP_mb=$'\E[01;34m'    # Blink (blue)
export LESS_TERMCAP_md=$'\E[01;36m'    # Bold (cyan)
export LESS_TERMCAP_me=$'\E[0m'        # Reset
export LESS_TERMCAP_se=$'\E[0m'        # Reset
export LESS_TERMCAP_so=$'\E[01;44;33m' # Standout (blue bg, yellow fg)
export LESS_TERMCAP_ue=$'\E[0m'        # Reset
export LESS_TERMCAP_us=$'\E[01;33m'    # Underline (yellow)

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ]; then
    export PATH="$HOME/bin:$PATH"
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/.local/bin" ]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# I think this was related to using GPG for git/SSH
export GPG_TTY=$(tty)

# if [[ -n "${WSL_DISTRO_NAME}" ]]; then
